# Example .env for qalc

# Alpaca API credentials
ALPACA_API_KEY_ID=your_alpaca_api_key_id_here
ALPACA_API_SECRET_KEY=your_alpaca_secret_key_here
ALPACA_TRADING_API_URL=https://paper-api.alpaca.markets
ALPACA_DATA_FEED=iex

# OpenAI API key (optional, for LLM integration)
OPENAI_API_KEY=your_openai_api_key_here

# LangSmith/Tracing (optional)
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT="https://api.smith.langchain.com"
LANGSMITH_API_KEY="your_langsmith_api_key_here"
LANGSMITH_PROJECT="qalc"
